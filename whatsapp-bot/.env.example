# Comma-separated WhatsApp JIDs allowed to message the bot.
# Format: <country-code><number>@s.whatsapp.net   (no +, no spaces)
# Example for +1 (415) 555-1234:  14155551234@s.whatsapp.net
# Easiest way to find yours: leave this blank, start the bot, message it from
# your phone, and copy the JID it prints in the console.
ALLOWED_JIDS=

# Directory the bot's tools operate inside. Defaults to the current working dir.
# Set this to sandbox the bot to a specific folder.
WORK_DIR=

# Optional log level for Baileys (silent | warn | info | debug). Default: warn
LOG_LEVEL=warn

# Leave UNSET to use your Claude Code subscription (recommended).
# Set to a key from console.anthropic.com to fall back to API billing.
# ANTHROPIC_API_KEY=
